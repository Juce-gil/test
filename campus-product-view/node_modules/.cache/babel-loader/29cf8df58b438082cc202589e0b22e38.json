G,CAACG,OAAJ,CAAY,MAAZ,MAAwB,CAAC,CAAzE;;AACA,QAAID,WAAJ,EAAiB;AACfpB,MAAAA,UAAU;AACVC,MAAAA,MAAM,CAACqB,IAAP,CAAY;AAAEC,QAAAA,IAAI,EAAE,QAAR;AAAkBC,QAAAA,KAAK,EAAE;AAAEC,UAAAA,QAAQ,EAAExB,MAAM,CAACyB,YAAP,CAAoBC;AAAhC;AAAzB,OAAZ;AACD;AACF;;AACD,SAAOZ,QAAP;AACD,CAZH,EAaEH,KAAK,IAAI;AACP,QAAMgB,GAAG,GAAGhB,KAAK,CAACG,QAAlB;;AACA,MAAIa,GAAG,IAAIA,GAAG,CAACC,MAAJ,KAAe,GAA1B,EAA+B;AAC7B7B,IAAAA,UAAU;AACVC,IAAAA,MAAM,CAACqB,IAAP,CAAY;AAAEC,MAAAA,IAAI,EAAE,QAAR;AAAkBC,MAAAA,KAAK,EAAE;AAAEC,QAAAA,QAAQ,EAAExB,MAAM,CAACyB,YAAP,CAAoBC;AAAhC;AAAzB,KAAZ;AACA,WAAOd,OAAO,CAACC,MAAR,CAAeF,KAAf,CAAP;AACD;;AACD,MAAIgB,GAAG,IAAIA,GAAG,CAACZ,IAAf,EAAqB;AACnB,UAAME,GAAG,GAAGU,GAAG,CAACZ,IAAJ,CAASG,OAAT,IAAoB,EAAhC;AACA,UAAMC,WAAW,GACdQ,GAAG,CAACZ,IAAJ,CAASC,IAAT,KAAkB,GAAlB,IAAyBC,GAAG,CAACG,OAAJ,CAAY,IAAZ,MAAsB,CAAC,CAAjD,IAAuDH,GAAG,CAACG,OAAJ,CAAY,MAAZ,MAAwB,CAAC,CADlF;;AAEA,QAAID,WAAJ,EAAiB;AACfpB,MAAAA,UAAU;AACVC,MAAAA,MAAM,CAACqB,IAAP,CAAY;AAAEC,QAAAA,IAAI,EAAE,QAAR;AAAkBC,QAAAA,KAAK,EAAE;AAAEC,UAAAA,QAAQ,EAAExB,MAAM,CAACyB,YAAP,CAAoBC;AAAhC;AAAzB,OAAZ;AACD;AACF;;AACD,SAAOd,OAAO,CAACC,MAAR,CAAeF,KAAf,CAAP;AACD,CA9BH;AAiCA,eAAeT,OAAf","sourcesContent":["import axios from \"axios\";\nimport { getToken, clearToken } from \"@/utils/storage.js\";\nimport router from \"@/router\";\n\n// 使用相对路径，开发时通过 vue.config.js 代理转发，部署时与前端同源\nexport const API_BASE_URL = \"/api/campus-product-sys/v1.0\";\n\nconst request = axios.create({\n  baseURL: API_BASE_URL,\n  timeout: 8000\n});\n\n// 请求拦截器\nrequest.interceptors.request.use(\n  config => {\n    const token = getToken();\n    if (token !== null && token !== \"\") {\n      config.headers[\"token\"] = token;\n    }\n    return config;\n  },\n  error => Promise.reject(error)\n);\n\n// 响应拦截器：认证失败时清除 token 并跳转登录\nrequest.interceptors.response.use(\n  response => {\n    const data = response.data;\n    if (data && data.code !== 200) {\n      const msg = data.message || \"\";\n      const isAuthError = msg.indexOf(\"登录\") !== -1 || msg.indexOf(\"身份认证\") !== -1;\n      if (isAuthError) {\n        clearToken();\n        router.push({ path: \"/login\", query: { redirect: router.currentRoute.fullPath } });\n      }\n    }\n    return response;\n  },\n  error => {\n    const res = error.response;\n    if (res && res.status === 401) {\n      clearToken();\n      router.push({ path: \"/login\", query: { redirect: router.currentRoute.fullPath } });\n      return Promise.reject(error);\n    }\n    if (res && res.data) {\n      const msg = res.data.message || \"\";\n      const isAuthError =\n        (res.data.code !== 200 && msg.indexOf(\"登录\") !== -1) || msg.indexOf(\"身份认证\") !== -1;\n      if (isAuthError) {\n        clearToken();\n        router.push({ path: \"/login\", query: { redirect: router.currentRoute.fullPath } });\n      }\n    }\n    return Promise.reject(error);\n  }\n);\n\nexport default request;\n"]}]}