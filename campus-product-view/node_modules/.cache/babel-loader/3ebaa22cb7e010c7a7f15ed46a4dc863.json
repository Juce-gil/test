,IAAA,GAAA,IAHA;AAIA,YAAA,gBAAA,EAAA,EAJA;AAKA;AACA,YAAA,WAAA,EAAA,KANA;AAOA,YAAA,eAAA,EAAA,IAPA;AAQA,YAAA,OAAA,EAAA,KAAA,IARA;AASA,YAAA,OAAA,EAAA;AACA,uBAAA,cAAA,CAAA,OAAA,CAAA,OAAA;AADA,aATA;;AAYA,YAAA,YAAA,CAAA,GAAA,EAAA,QAAA,EAAA;AACA,cAAA,QAAA,CAAA,GAAA,CAAA,IAAA,EAAA,GAAA,CAAA,IAAA,EAAA,GAAA,CAAA,IAAA,CAAA;AACA;;AAdA;AADA;AAFA,OAJA;AAyBA,MAAA,IAAA,EAAA;AAzBA,KAAA;AA2BA,GAzCA;;AA0CA,EAAA,OAAA,EAAA;AACA,IAAA,SAAA,CAAA,MAAA,EAAA;AACA,WAAA,MAAA,GAAA,MAAA,CAAA,IAAA,CAAA,MAAA,CAAA;AACA,WAAA,aAAA,CAAA,WAAA,GAAA,CAAA,aAAA,EAAA,aAAA,CAAA;AACA;;AAJA,GA1CA;AAgDA,EAAA,KAAA,EAAA;AACA,IAAA,cAAA,EAAA;AACA,MAAA,OAAA,CAAA,EAAA,EAAA,EAAA,EAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,OAAA,EAAA,EAAA;AACA,aAAA,OAAA,GAAA,EAAA;AACA,OAJA;;AAKA,MAAA,IAAA,EAAA,IALA;AAKA;AACA,MAAA,SAAA,EAAA;AANA,KADA;;AASA,IAAA,OAAA,CAAA,MAAA,EAAA,MAAA,EAAA;AACA,WAAA,KAAA,CAAA,YAAA,EAAA,MAAA;AACA;;AAXA,GAhDA;;AA6DA,EAAA,aAAA,GAAA;AACA,UAAA,MAAA,GAAA,KAAA,MAAA;AACA,QAAA,MAAA,IAAA,IAAA,EAAA;AACA,IAAA,MAAA,CAAA,OAAA;AACA;;AAjEA,CAAA,CAAA","sourcesContent":["<template>\n    <div>\n        <Toolbar style=\"border-bottom: 1px solid #eae8e8;\" :editor=\"editor\" :defaultConfig=\"toolbarConfig\"\n            :mode=\"mode\" />\n        <Editor :style=\"{ height: height, overflowY: 'hidden' }\" v-model=\"content\" :defaultConfig=\"editorConfig\"\n            :mode=\"mode\" @onCreated=\"onCreated\" />\n    </div>\n</template>\n<script>\nimport Vue from 'vue';\nimport { Editor, Toolbar } from '@wangeditor/editor-for-vue';\nimport { API_BASE_URL } from '@/utils/request';\nexport default Vue.extend({\n    components: { Editor, Toolbar },\n    props: {\n        receiveContent: {\n            type: String,\n            default: '',\n            required: true\n        },\n        height: {\n            type: String,\n            default: 'calc(100vh - 100px)'\n        }\n    },\n    data() {\n        return {\n            editor: null,\n            content: '<p>创作内容</p>',\n            toolbarConfig: {},\n            editorConfig: {\n                placeholder: '请输入内容...',\n                MENU_CONF: {\n                    uploadImage: {\n                        server: API_BASE_URL + '/file/upload',\n                        fieldName: 'file',\n                        maxFileSize: 10 * 1024 * 1024,\n                        maxNumberOfFiles: 10,\n                        // allowedFileTypes: ['image/*'],\n                        metaWithUrl: false,\n                        withCredentials: true,\n                        timeout: 10 * 1000,\n                        headers: {\n                            'token': sessionStorage.getItem('token')\n                        },\n                        customInsert(res, insertFn) {\n                            insertFn(res.data, res.data, res.data);\n                        },\n                    },\n                }\n            },\n            mode: 'default',\n        }\n    },\n    methods: {\n        onCreated(editor) {\n            this.editor = Object.seal(editor);\n            this.toolbarConfig.excludeKeys = ['group-video','group-image'];\n        },\n    },\n    watch: {\n        receiveContent: {\n            handler(v1, v2) {\n                console.log(\"接收内容：\", v1);\n                this.content = v1;\n            },\n            deep: true, // 启用深度监听  \n            immediate: true\n        },\n        content(newVal, oldVal) {\n            this.$emit('on-receive', newVal);\n        },\n    },\n    beforeDestroy() {\n        const editor = this.editor;\n        if (editor == null) return;\n        editor.destroy();\n    }\n})\n</script>\n<style src=\"@wangeditor/editor/dist/css/style.css\"></style>\n<style scoped>\n.line-number {\n    display: block;\n    margin-right: 10px;\n    /* 以下样式确保行号不被选中或复制 */\n    pointer-events: none;\n    user-select: none;\n    -webkit-user-select: none;\n    color: #999;\n    /* 行号颜色，可自定义 */\n    text-align: right;\n    /* 行号对齐方式 */\n}\n</style>\n```\n\n<h1 id=\"rxGCi\">后端</h1>\n使用下列的新增语句替换ProductMapper.xml里面的商品新增SQL\n\n![](https://cdn.nlark.com/yuque/0/2024/png/32649796/1734090641680-a6241eda-29b2-443a-a5fb-d56c11c6ce24.png)\n\n```xml\n<insert id=\"save\">\n  INSERT INTO product (name, detail, cover_list, old_level, category_id, user_id, inventory, price, is_bargain,\n  create_time)\n  VALUES (#{name}, #{detail}, #{coverList}, #{oldLevel}, #{categoryId}, #{userId}, #{inventory}, #{price},\n  #{isBargain}, #{createTime})\n</insert>"],"sourceRoot":"src/components"}]}