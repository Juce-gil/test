A,aAAA,OAAA,CAAA,IAAA,CAAA;AACA,UAAA,QAAA,EAAA,IADA;AAEA,UAAA,KAAA,EAAA,MAFA;AAGA,UAAA,OAAA,EAAA;AAHA,SAAA;AAKA;AACA;;AACA,UAAA,KAAA,OAAA,CAAA,KAAA,KAAA,SAAA,EAAA;AACA,aAAA,OAAA,CAAA,IAAA,CAAA;AACA,UAAA,QAAA,EAAA,IADA;AAEA,UAAA,KAAA,EAAA,MAFA;AAGA,UAAA,OAAA,EAAA;AAHA,SAAA;AAKA;AACA;;AACA,UAAA,KAAA,SAAA,CAAA,MAAA,KAAA,CAAA,EAAA;AACA,aAAA,OAAA,CAAA,IAAA,CAAA;AACA,UAAA,QAAA,EAAA,IADA;AAEA,UAAA,KAAA,EAAA,MAFA;AAGA,UAAA,OAAA,EAAA;AAHA,SAAA;AAKA;AACA;;AACA,WAAA,OAAA,CAAA,SAAA,GAAA,KAAA,SAAA,CAAA,IAAA,CAAA,GAAA,CAAA,CAzBA,CA0BA;;AACA,WAAA,MAAA,CAAA,IAAA,CAAA,eAAA,EAAA,KAAA,OAAA,EAAA,IAAA,CAAA,GAAA,IAAA;AACA,cAAA;AAAA,UAAA;AAAA,YAAA,GAAA;;AACA,YAAA,IAAA,CAAA,IAAA,KAAA,GAAA,EAAA;AACA,eAAA,OAAA,CAAA,OAAA,CAAA;AACA,YAAA,KAAA,EAAA,MADA;AAEA,YAAA,OAAA,EAAA,IAAA,CAAA;AAFA,WAAA,EADA,CAKA;AACA;AACA;AACA,OAVA,EAUA,KAVA,CAUA,KAAA,IAAA;AACA,aAAA,OAAA,CAAA,KAAA,CAAA;AACA,UAAA,KAAA,EAAA,MADA;AAEA,UAAA,OAAA,EAAA;AAFA,SAAA;AAIA,QAAA,OAAA,CAAA,GAAA,CAAA,SAAA,EAAA,KAAA;AACA,OAhBA;AAiBA,KAhDA;;AAiDA;AACA;AACA;AACA;AACA,IAAA,SAAA,CAAA,MAAA,EAAA;AACA,WAAA,OAAA,CAAA,MAAA,GAAA,MAAA;AACA,KAvDA;;AAwDA;AACA;AACA;AACA;AACA,IAAA,aAAA,CAAA,QAAA,EAAA;AACA,WAAA,gBAAA,GAAA,QAAA;AACA,WAAA,OAAA,CAAA,UAAA,GAAA,QAAA,CAAA,EAAA;AACA,KA/DA;;AAgEA;AACA;AACA;AACA,IAAA,iBAAA,GAAA;AACA,WAAA,MAAA,CAAA,IAAA,CAAA,iBAAA,EAAA,EAAA,EAAA,IAAA,CAAA,GAAA,IAAA;AACA,cAAA;AAAA,UAAA;AAAA,YAAA,GAAA;;AACA,YAAA,IAAA,CAAA,IAAA,KAAA,GAAA,EAAA;AACA,eAAA,YAAA,GAAA,IAAA,CAAA,IAAA,CADA,CAEA;;AACA,eAAA,aAAA,CAAA,KAAA,YAAA,CAAA,CAAA,CAAA;AACA;AACA,OAPA,EAOA,KAPA,CAOA,KAAA,IAAA;AACA,QAAA,OAAA,CAAA,GAAA,CAAA,aAAA,EAAA,KAAA;AACA,OATA;AAUA,KA9EA;;AA+EA;AACA;AACA;AACA,IAAA,YAAA,GAAA;AACA,MAAA,OAAA,CAAA,GAAA,CAAA,OAAA,EAAA,KAAA,QAAA;AACA,WAAA,OAAA,CAAA,QAAA,GAAA,KAAA,QAAA;AACA,KArFA;;AAsFA;AACA;AACA;AACA,IAAA,qBAAA,GAAA;AACA,MAAA,OAAA,CAAA,GAAA,CAAA,KAAA,EAAA,KAAA,SAAA;AACA,WAAA,OAAA,CAAA,SAAA,GAAA,KAAA,SAAA;AACA,KA5FA;;AA6FA;AACA;AACA;AACA;AACA;AACA,IAAA,wBAAA,CAAA,IAAA,EAAA,QAAA,EAAA;AACA,WAAA,SAAA,CAAA,IAAA,CAAA,IAAA,CAAA,IAAA;AACA,KApGA;;AAqGA,IAAA,YAAA,CAAA,IAAA,EAAA,QAAA,EAAA;AACA,WAAA,SAAA,GAAA,QAAA;AACA,MAAA,OAAA,CAAA,GAAA,CAAA,IAAA,EAAA,QAAA;AACA,KAxGA;;AAyGA,IAAA,wBAAA,CAAA,IAAA,EAAA;AACA,WAAA,cAAA,GAAA,IAAA,CAAA,GAAA;AACA,WAAA,aAAA,GAAA,IAAA;AACA;;AA5GA;AAnBA,CAAA","sourcesContent":["<template>\n    <div class=\"post-product\">\n        <div>\n            <div>\n                <p>商品名</p>\n                <input class=\"dialog-input\" v-model=\"product.name\" placeholder=\"商品名\" />\n            </div>\n            <div>\n                <p>新旧程度</p>\n                <el-input-number v-model=\"oldLevel\" @change=\"handleChange\" :min=\"1\" :max=\"10\"\n                    label=\"新旧程度\"></el-input-number>\n            </div>\n            <div>\n                <p>价格</p>\n                <input class=\"dialog-input\" v-model=\"product.price\" placeholder=\"价格\" />\n            </div>\n            <div>\n                <p>是否支持砍价</p>\n                <el-switch v-model=\"product.isBargain\" active-text=\"支持砍价\" inactive-text=\"不支持砍价\">\n                </el-switch>\n            </div>\n            <div>\n                <span class=\"post\" @click=\"postProduct\">发布商品</span>\n            </div>\n        </div>\n        <div>\n            <div>\n                <p>产品图</p>\n                <el-upload :action=\"uploadAction\"\n                    list-type=\"picture-card\" :on-success=\"handlePictureCardSuccess\"\n                    :on-preview=\"handlePictureCardPreview\" :on-remove=\"handleRemove\">\n                    <i class=\"el-icon-plus\"></i>\n                </el-upload>\n                <el-dialog :visible.sync=\"dialogVisible\">\n                    <img width=\"100%\" :src=\"dialogImageUrl\" alt=\"\">\n                </el-dialog>\n            </div>\n            <div>\n                <p>所属商品类别</p>\n                <span :style=\"{\n                    backgroundColor: categorySelected.id === category.id ? 'rgb(76, 147, 209)' : '',\n                    color: categorySelected.id === category.id ? 'rgb(244,244,244)' : ''\n                }\" class=\"category-item\" @click=\"categoryClick(category)\" v-for=\"(category, index) in categoryList\"\n                    :key=\"index\">\n                    {{ category.name }}\n                </span>\n            </div>\n            <div>\n                <p>库存</p>\n                <el-input-number v-model=\"inventory\" @change=\"handleInventoryChange\" :min=\"1\" :max=\"10000\"\n                    label=\"新旧程度\"></el-input-number>\n            </div>\n            <div>\n                <Editor height=\"calc(100vh - 400px)\" :receiveContent=\"product.detail\" @on-receive=\"onReceive\" />\n            </div>\n\n        </div>\n    </div>\n</template>\n<script>\nimport Editor from \"@/components/Editor\";\nimport { API_BASE_URL } from \"@/utils/request\";\nexport default {\n    components: { Editor },\n    name: 'PostProduct',\n    data() {\n        return {\n            uploadAction: API_BASE_URL + \"/file/upload\",\n            oldLevel: 9, // 默认九成新\n            inventory: 1, // 默认库存\n            product: {},\n            categorySelected: {}, // 当前选中的商品类别\n            dialogImageUrl: '',\n            dialogVisible: false,\n            coverList: [],\n            categoryList: []\n        };\n    },\n    created() {\n        this.fetchCategoryList();\n    },\n    methods: {\n        /**\n         * 发布商品\n         */\n        postProduct() {\n            if (this.product.name === undefined) {\n                this.$notify.info({\n                    duration: 1000,\n                    title: '填写提醒',\n                    message: '商品标题不能为空'\n                });\n                return;\n            }\n            if (this.product.price === undefined) {\n                this.$notify.info({\n                    duration: 1000,\n                    title: '填写提醒',\n                    message: '商品价格不能为空'\n                });\n                return;\n            }\n            if (this.coverList.length === 0) {\n                this.$notify.info({\n                    duration: 1000,\n                    title: '上传提醒',\n                    message: '请上传封面'\n                });\n                return;\n            }\n            this.product.coverList = this.coverList.join(',');\n            // 商品封面需要处理\n            this.$axios.post('/product/save', this.product).then(res => {\n                const { data } = res;\n                if (data.code === 200) {\n                    this.$notify.success({\n                        title: '发布操作',\n                        message: data.msg\n                    });\n                    // 后续清除之后，跳转我的商品页面\n                    // this.product = {};\n                }\n            }).catch(error => {\n                this.$notify.error({\n                    title: '发布操作',\n                    message: error\n                });\n                console.log(\"新增商品异常:\", error);\n            });\n        },\n        /**\n         * 富文本编辑器回调内容\n         * @param {*} detail \n         */\n        onReceive(detail) {\n            this.product.detail = detail;\n        },\n        /**\n         * 商品分类选中事件\n         * @param {*} category 商品分类\n         */\n        categoryClick(category) {\n            this.categorySelected = category;\n            this.product.categoryId = category.id;\n        },\n        /**\n         * 查询商品类别\n         */\n        fetchCategoryList() {\n            this.$axios.post('/category/query', {}).then(res => {\n                const { data } = res;\n                if (data.code === 200) {\n                    this.categoryList = data.data;\n                    // 默认选中第一项\n                    this.categoryClick(this.categoryList[0]);\n                }\n            }).catch(error => {\n                console.log(\"查询商品类别信息异常:\", error);\n            });\n        },\n        /**\n         * 新旧程度选择事件\n         */\n        handleChange() {\n            console.log(\"新旧程度：\", this.oldLevel);\n            this.product.oldLevel = this.oldLevel;\n        },\n        /**\n         * 库存设置事件\n         */\n        handleInventoryChange() {\n            console.log(\"库存：\", this.inventory);\n            this.product.inventory = this.inventory;\n        },\n        /**\n         * 封面上传成功响应事件\n         * @param {*} file \n         * @param {*} fileList \n         */\n        handlePictureCardSuccess(file, fileList) {\n            this.coverList.push(file.data);\n        },\n        handleRemove(file, fileList) {\n            this.coverList = fileList\n            console.log(file, fileList);\n        },\n        handlePictureCardPreview(file) {\n            this.dialogImageUrl = file.url;\n            this.dialogVisible = true;\n        }\n    }\n};\n</script>\n<style scoped lang=\"scss\">\n.post {\n    display: inline-block;\n    background-color: rgb(51, 51, 51);\n    margin-block: 30px;\n    width: 100%;\n    text-align: center;\n    padding: 15px;\n    box-sizing: border-box;\n    color: rgb(245, 245, 245);\n    border-radius: 5px;\n    font-size: 14px;\n    cursor: pointer;\n}\n\n.post:hover {\n    background-color: rgb(31, 31, 31);\n}\n\n.category-item {\n    display: inline-block;\n    padding: 6px 20px;\n    background-color: rgb(246, 246, 246);\n    border-radius: 5px;\n    font-size: 14px;\n    cursor: pointer;\n    margin: 4px;\n}\n\n.category-item:hover {\n    background-color: rgb(241, 241, 241);\n}\n\n.post-product {\n    display: flex;\n    justify-content: left;\n    gap: 30px;\n}\n</style>"],"sourceRoot":"src/views/user"}]}