A,GAAA,CAAA,MAAA,IAAA,MAAA,CAAA,EAAA,CAAA;AACA,gBAAA,QAAA,GAAA,MAAA,KAAA,MAAA,CAAA,IAAA,CAAA,0BAAA,EAAA,GAAA,CAAA;;AACA,cAAA,QAAA,CAAA,IAAA,CAAA,IAAA,KAAA,GAAA,EAAA;AACA,iBAAA,OAAA,CAAA;AACA,cAAA,QAAA,EAAA,IADA;AAEA,cAAA,KAAA,EAAA,MAFA;AAGA,cAAA,OAAA,EAAA,MAHA;AAIA,cAAA,IAAA,EAAA;AAJA,aAAA;AAMA,iBAAA,cAAA;AACA;AACA;AACA,SAbA,CAaA,OAAA,KAAA,EAAA;AACA,eAAA,QAAA,CAAA,KAAA,CAAA,WAAA,EAAA,KAAA;AACA,UAAA,OAAA,CAAA,KAAA,CAAA,WAAA,EAAA,KAAA;AACA;AACA;AACA,KA/BA;;AAgCA;AACA;AACA;AACA,IAAA,cAAA,GAAA;AACA,WAAA,mBAAA,CAAA,OAAA,GAAA,KAAA,WAAA;AACA,WAAA,mBAAA,CAAA,IAAA,GAAA,KAAA,QAAA;AACA,WAAA,MAAA,CAAA,IAAA,CAAA,oBAAA,EAAA,KAAA,mBAAA,EAAA,IAAA,CAAA,GAAA,IAAA;AACA,cAAA;AAAA,UAAA;AAAA,YAAA,GAAA,CADA,CACA;;AACA,YAAA,IAAA,CAAA,IAAA,KAAA,GAAA,EAAA;AACA,eAAA,SAAA,GAAA,IAAA,CAAA,IAAA;AACA,eAAA,UAAA,GAAA,IAAA,CAAA,KAAA;AACA;AACA,OANA,EAMA,KANA,CAMA,KAAA,IAAA;AACA,aAAA,OAAA,CAAA,KAAA,CAAA;AACA,UAAA,KAAA,EAAA,MADA;AAEA,UAAA,OAAA,EAAA;AAFA,SAAA;AAIA,OAXA;AAYA,KAlDA;;AAmDA,IAAA,YAAA,GAAA;AACA,WAAA,WAAA,GAAA,CAAA;AACA,WAAA,cAAA;AACA,KAtDA;;AAuDA,IAAA,iBAAA,GAAA;AACA,WAAA,YAAA;AACA,KAzDA;;AA0DA,IAAA,gBAAA,CAAA,GAAA,EAAA;AACA,WAAA,QAAA,GAAA,GAAA;AACA,WAAA,WAAA,GAAA,CAAA;AACA,WAAA,cAAA;AACA,KA9DA;;AA+DA,IAAA,mBAAA,CAAA,GAAA,EAAA;AACA,WAAA,WAAA,GAAA,GAAA;AACA,WAAA,cAAA;AACA,KAlEA;;AAmEA,IAAA,YAAA,CAAA,GAAA,EAAA;AACA,WAAA,YAAA,CAAA,IAAA,CAAA,GAAA;AACA,WAAA,WAAA;AACA;;AAtEA;AAfA,CAAA","sourcesContent":["<template>\r\n    <el-row style=\"background-color: #FFFFFF;padding: 5px 0;border-radius: 5px;\">\r\n        <el-row style=\"padding: 10px;margin-left: 5px;\">\r\n            <el-row>\r\n                <el-input size=\"small\" style=\"width: 166px;\" v-model=\"interactionQueryDto.productId\" placeholder=\"商品ID\"\r\n                    clearable @clear=\"handleFilterClear\">\r\n                    <el-button slot=\"append\" @click=\"handleFilter\" icon=\"el-icon-search\"></el-button>\r\n                </el-input>\r\n            </el-row>\r\n        </el-row>\r\n        <el-row style=\"margin: 0 22px;border-top: 1px solid rgb(245,245,245);\">\r\n            <el-table :stripe=\"true\" :data=\"tableData\">\r\n                <el-table-column prop=\"userAccount\" width=\"168\" label=\"用户账号\"></el-table-column>\r\n                <el-table-column prop=\"userName\" width=\"228\" label=\"用户名\"></el-table-column>\r\n                <el-table-column prop=\"productId\" width=\"148\" :sortable=\"true\" label=\"商品ID\"></el-table-column>\r\n                <el-table-column prop=\"productTitle\" label=\"商品名\"></el-table-column>\r\n                <el-table-column prop=\"type\" width=\"228\" label=\"行为类型\">\r\n                    <template slot-scope=\"scope\">\r\n                        <span>{{ scope.row.type === 1 ? '收藏操作' : (scope.row.type === 2 ? '浏览操作' : '想要操作') }}</span>\r\n                    </template>\r\n                </el-table-column>\r\n                <el-table-column prop=\"createTime\" width=\"208\" :sortable=\"true\" label=\"互动时间\"></el-table-column>\r\n                <el-table-column label=\"操作\" width=\"120\">\r\n                    <template slot-scope=\"scope\">\r\n                        <span class=\"text-button\" @click=\"handleDelete(scope.row)\">删除</span>\r\n                    </template>\r\n                </el-table-column>\r\n            </el-table>\r\n            <el-pagination style=\"margin:10px 0;float: right;\" @size-change=\"handleSizeChange\"\r\n                @current-change=\"handleCurrentChange\" :current-page=\"currentPage\" :page-sizes=\"[10, 20]\"\r\n                :page-size=\"pageSize\" layout=\"total, sizes, prev, pager, next, jumper\"\r\n                :total=\"totalItems\"></el-pagination>\r\n        </el-row>\r\n    </el-row>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n    data() {\r\n        return {\r\n            data: {},\r\n            currentPage: 1,\r\n            pageSize: 10,\r\n            totalItems: 0,\r\n            tableData: [],\r\n            delectedRows: [],\r\n            interactionQueryDto: {}, // 搜索条件\r\n        };\r\n    },\r\n    created() {\r\n        this.fetchFreshData();\r\n    },\r\n    methods: {\r\n        // 批量删除数据\r\n        async batchDelete() {\r\n            if (!this.delectedRows.length) {\r\n                this.$message(`未选中任何数据`);\r\n                return;\r\n            }\r\n            const confirmed = await this.$swalConfirm({\r\n                title: '删除互动数据',\r\n                text: `删除后不可恢复，是否继续？`,\r\n                icon: 'warning',\r\n            });\r\n            if (confirmed) {\r\n                try {\r\n                    let ids = this.delectedRows.map(entity => entity.id);\r\n                    const response = await this.$axios.post(`/interaction/batchDelete`, ids);\r\n                    if (response.data.code === 200) {\r\n                        this.$notify({\r\n                            duration: 1000,\r\n                            title: '信息删除',\r\n                            message: '删除成功',\r\n                            type: 'success'\r\n                        });\r\n                        this.fetchFreshData();\r\n                        return;\r\n                    }\r\n                } catch (error) {\r\n                    this.$message.error(\"互动信息删除异常：\", error);\r\n                    console.error(`互动信息删除异常：`, error);\r\n                }\r\n            }\r\n        },\r\n        /**\r\n         * 互动查询\r\n         */\r\n        fetchFreshData() {\r\n            this.interactionQueryDto.current = this.currentPage;\r\n            this.interactionQueryDto.size = this.pageSize;\r\n            this.$axios.post('/interaction/query', this.interactionQueryDto).then(res => {\r\n                const { data } = res; // 解构\r\n                if (data.code === 200) {\r\n                    this.tableData = data.data;\r\n                    this.totalItems = data.total;\r\n                }\r\n            }).catch(error => {\r\n                this.$notify.error({\r\n                    title: '查询操作',\r\n                    message: error\r\n                });\r\n            })\r\n        },\r\n        handleFilter() {\r\n            this.currentPage = 1;\r\n            this.fetchFreshData();\r\n        },\r\n        handleFilterClear() {\r\n            this.handleFilter();\r\n        },\r\n        handleSizeChange(val) {\r\n            this.pageSize = val;\r\n            this.currentPage = 1;\r\n            this.fetchFreshData();\r\n        },\r\n        handleCurrentChange(val) {\r\n            this.currentPage = val;\r\n            this.fetchFreshData();\r\n        },\r\n        handleDelete(row) {\r\n            this.delectedRows.push(row);\r\n            this.batchDelete();\r\n        }\r\n    },\r\n};\r\n</script>\r\n<style scoped lang=\"scss\"></style>"],"sourceRoot":"src/views/admin"}]}