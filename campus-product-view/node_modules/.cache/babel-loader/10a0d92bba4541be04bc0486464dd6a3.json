{"remainingRequest":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\babel-loader\\lib\\index.js!F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\cache-loader\\dist\\cjs.js??ref--0-0!F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!F:\\campus-system\\campus-system\\source code\\campus-product-view\\src\\views\\user\\Myself.vue?vue&type=script&lang=js&","dependencies":[{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\src\\views\\user\\Myself.vue","mtime":1773295550757},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1770519914424},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\babel-loader\\lib\\index.js","mtime":1770519916968},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1770519914424},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\vue-loader\\lib\\index.js","mtime":1770519916415}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Myself.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA+BA,OAAA,QAAA,MAAA,uBAAA;AACA,OAAA,IAAA,MAAA,mBAAA;AACA,eAAA;AACA,EAAA,UAAA,EAAA;AAAA,IAAA,QAAA;AAAA,IAAA;AAAA,GADA;;AAEA,EAAA,IAAA,GAAA;AACA,WAAA;AACA,MAAA,IAAA,EAAA,CAAA,MAAA,EAAA,MAAA,EAAA,MAAA,CADA;AAEA,MAAA,WAAA,EAAA,EAFA;AAGA,MAAA,WAAA,EAAA;AAHA,KAAA;AAKA,GARA;;AASA,EAAA,OAAA,GAAA;AACA,SAAA,gBAAA;AACA,GAXA;;AAYA,EAAA,KAAA,EAAA;AACA,wBAAA;AACA,MAAA,SAAA,EAAA,KADA;;AAEA,MAAA,OAAA,GAAA;AACA,aAAA,gBAAA;AACA;;AAJA;AADA,GAZA;AAoBA,EAAA,OAAA,EAAA;AACA,IAAA,QAAA,GAAA;AACA,MAAA,cAAA,CAAA,OAAA,CAAA,OAAA,EAAA,IAAA;AACA,MAAA,cAAA,CAAA,OAAA,CAAA,UAAA,EAAA,IAAA;AACA,WAAA,OAAA,CAAA,IAAA,CAAA,QAAA;AACA,KALA;;AAMA;AACA,IAAA,gBAAA,GAAA;AACA,YAAA,GAAA,GAAA,KAAA,MAAA,CAAA,KAAA,CAAA,GAAA;;AACA,UAAA,GAAA,KAAA,KAAA,EAAA;AACA,aAAA,WAAA,GAAA,MAAA;AACA,OAFA,MAEA;AACA;AACA,aAAA,WAAA,GAAA,KAAA,WAAA;AACA;AACA,KAfA;;AAgBA,IAAA,SAAA,CAAA,GAAA,EAAA;AACA,WAAA,WAAA,GAAA,GAAA;AACA,KAlBA;;AAmBA,IAAA,UAAA,GAAA;AACA,WAAA,OAAA,CAAA,EAAA,CAAA,CAAA,CAAA;AACA;;AArBA;AApBA,CAAA","sourcesContent":["<template>\n    <div class=\"container-self\">\n        <div class=\"container-self-top\">\n            <div class=\"title\">个人中心</div>\n        </div>\n        <div class=\"item\">\n            <span :style=\"{\n                fontWeight: tagSelected === tagItem ? '800' : '',\n                color: tagSelected === tagItem ? 'rgb(51,51,51)' : '',\n                backgroundColor: tagSelected === tagItem ? 'rgb(247, 247, 247)' : ''\n            }\" @click=\"condition(tagItem)\" v-for=\"(tagItem, index) in tags\" :key=\"index\">\n                {{ tagItem }}\n            </span>\n        </div>\n        <div v-if=\"tagSelected === '修改资料'\">\n            <Self />\n        </div>\n        <div v-else-if=\"tagSelected === '修改密码'\">\n            <ResetPwd />\n        </div>\n        <div v-else-if=\"tagSelected === '退出登录'\">\n            <el-result icon=\"warning\" title=\"退出\" subTitle=\"退出后将重新登录\">\n                <template slot=\"extra\">\n                    <span class=\"loginout\" @click=\"loginout\">我确定</span>\n                </template>\n            </el-result>\n        </div>\n    </div>\n</template>\n\n<script>\nimport ResetPwd from '@/views/user/ResetPwd'\nimport Self from '@/views/user/Self'\nexport default {\n    components: { ResetPwd, Self },\n    data() {\n        return {\n            tags: ['修改资料', '修改密码', '退出登录'],\n            tagSelected: '',\n            defaultPath: '修改资料',\n        };\n    },\n    created() {\n        this.syncTabFromRoute();\n    },\n    watch: {\n        '$route.query.tab': {\n            immediate: false,\n            handler() {\n                this.syncTabFromRoute();\n            }\n        }\n    },\n    methods: {\n        loginout() {\n            sessionStorage.setItem('token', null);\n            sessionStorage.setItem('userInfo', null);\n            this.$router.push('/login');\n        },\n        // 根据路由参数同步当前选中的标签\n        syncTabFromRoute() {\n            const tab = this.$route.query.tab;\n            if (tab === 'pwd') {\n                this.tagSelected = '修改密码';\n            } else {\n                // 默认或其他值都回到“修改资料”\n                this.tagSelected = this.defaultPath;\n            }\n        },\n        condition(tag) {\n            this.tagSelected = tag;\n        },\n        returnPage() {\n            this.$router.go(-1);\n        },\n    },\n};\n</script>\n<style scoped lang=\"scss\">\n.loginout{\n    display: inline-block;\n    color: rgb(245,245,245);\n    background-color: rgb(51,51,51);\n    border-radius: 5px;\n    padding: 4px 30px;\n    cursor: pointer;\n}\n.loginout:hover{\n    background-color: rgb(34, 34, 34);\n}\n.item {\n    width: 800px;\n    padding-block: 10px;\n    margin-block: 20px;\n    display: flex;\n    justify-content: left;\n    gap: 4px;\n\n    span {\n        font-size: 16px;\n        cursor: pointer;\n        display: inline-block;\n        transition: all .2s;\n        padding: 10px 20px;\n        border-radius: 10px;\n    }\n\n    span:hover {\n        background-color: rgb(246, 246, 246);\n    }\n\n}\n\n\n.container-self {\n    width: 800px;\n    margin: 0 auto;\n    padding: 50px 30px;\n\n    .container-self-top {\n        display: flex;\n        justify-content: left;\n        align-items: center;\n        gap: 8px;\n        margin-top: 15px;\n\n        .return-page {\n            padding: 20px;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n\n        .return-page:hover {\n            background-color: rgb(248, 248, 248);\n        }\n\n        .title {\n            font-size: 30px;\n            font-weight: 800;\n        }\n    }\n}\n</style>"],"sourceRoot":"src/views/user"}]}