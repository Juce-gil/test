AAAA,QAAA,IAAA,EAAA;AAAA,OAAA,EAAA;AAAA,QAAA,YAAA,EAAA,IAAA;AAAA,QAAA,IAAA,EAAA;AAAA,OAAA,EAAA;AAAA,QAAA,YAAA,EAAA,KAAA;AAAA,QAAA,IAAA,EAAA;AAAA,OAAA,CAlBA;AAmBA,MAAA,WAAA,EAAA,CAAA;AAAA,QAAA,WAAA,EAAA,IAAA;AAAA,QAAA,IAAA,EAAA;AAAA,OAAA,EAAA;AAAA,QAAA,WAAA,EAAA,IAAA;AAAA,QAAA,IAAA,EAAA;AAAA,OAAA,EAAA;AAAA,QAAA,WAAA,EAAA,KAAA;AAAA,QAAA,IAAA,EAAA;AAAA,OAAA;AAnBA,KAAA;AAqBA,GAvBA;;AAwBA,EAAA,OAAA,GAAA;AACA,SAAA,cAAA,GADA,CAEA;;AACA,SAAA,aAAA,CAAA,KAAA,WAAA,CAAA,CAAA,CAAA;AACA,GA5BA;;AA6BA,EAAA,OAAA,EAAA;AACA;AACA;AACA;AACA;AACA,IAAA,aAAA,CAAA,KAAA,EAAA;AACA,WAAA,iBAAA,GAAA,KAAA;AACA,WAAA,cAAA,CAAA,WAAA,GAAA,KAAA,CAAA,WAAA;AACA,WAAA,cAAA;AACA,KATA;;AAUA,IAAA,cAAA,CAAA,MAAA,EAAA;AACA,WAAA,kBAAA,GAAA,MAAA;AACA,WAAA,cAAA,CAAA,YAAA,GAAA,MAAA,CAAA,YAAA;AACA,WAAA,cAAA;AACA,KAdA;;AAeA;AACA;AACA;AACA;AACA,IAAA,cAAA,CAAA,KAAA,EAAA;AACA,WAAA,KAAA,GAAA,KAAA;AACA,WAAA,oBAAA,GAAA,IAAA;AACA,KAtBA;;AAuBA,IAAA,MAAA,GAAA;AACA,WAAA,IAAA,GAAA,EAAA;AACA,WAAA,qBAAA,GAAA,KAAA;AACA,WAAA,WAAA,GAAA,KAAA;AACA,KA3BA;;AA4BA;AACA,UAAA,WAAA,GAAA;AACA,UAAA,CAAA,KAAA,YAAA,CAAA,MAAA,EAAA;AACA,aAAA,QAAA,CAAA,SAAA;AACA;AACA;;AACA,YAAA,SAAA,GAAA,MAAA,KAAA,YAAA,CAAA;AACA,QAAA,KAAA,EAAA,QADA;AAEA,QAAA,IAAA,EAAA,eAFA;AAGA,QAAA,IAAA,EAAA;AAHA,OAAA,CAAA;;AAKA,UAAA,SAAA,EAAA;AACA,YAAA;AACA,cAAA,GAAA,GAAA,KAAA,YAAA,CAAA,GAAA,CAAA,MAAA,IAAA,MAAA,CAAA,EAAA,CAAA;AACA,gBAAA,QAAA,GAAA,MAAA,KAAA,MAAA,CAAA,IAAA,CAAA,qBAAA,EAAA,GAAA,CAAA;;AACA,cAAA,QAAA,CAAA,IAAA,CAAA,IAAA,KAAA,GAAA,EAAA;AACA,iBAAA,OAAA,CAAA;AACA,cAAA,QAAA,EAAA,IADA;AAEA,cAAA,KAAA,EAAA,MAFA;AAGA,cAAA,OAAA,EAAA,MAHA;AAIA,cAAA,IAAA,EAAA;AAJA,aAAA;AAMA,iBAAA,cAAA;AACA;AACA;AACA,SAbA,CAaA,OAAA,KAAA,EAAA;AACA,eAAA,QAAA,CAAA,KAAA,CAAA,WAAA,EAAA,KAAA;AACA,UAAA,OAAA,CAAA,KAAA,CAAA,WAAA,EAAA,KAAA;AACA;AACA;AACA,KA1DA;;AA2DA;AACA;AACA;AACA,UAAA,cAAA,GAAA;AACA,UAAA,SAAA,GAAA,IAAA;AACA,UAAA,OAAA,GAAA,IAAA;;AACA,UAAA,KAAA,UAAA,IAAA,IAAA,IAAA,KAAA,UAAA,CAAA,MAAA,KAAA,CAAA,EAAA;AACA,cAAA,CAAA,SAAA,EAAA,OAAA,IAAA,MAAA,OAAA,CAAA,GAAA,CAAA,KAAA,UAAA,CAAA,GAAA,CAAA,IAAA,IAAA,IAAA,CAAA,WAAA,EAAA,CAAA,CAAA;AACA,QAAA,SAAA,GAAA,GAAA,SAAA,CAAA,KAAA,CAAA,GAAA,EAAA,CAAA,CAAA,WAAA;AACA,QAAA,OAAA,GAAA,GAAA,OAAA,CAAA,KAAA,CAAA,GAAA,EAAA,CAAA,CAAA,WAAA;AACA;;AACA,WAAA,cAAA,CAAA,OAAA,GAAA,KAAA,WAAA;AACA,WAAA,cAAA,CAAA,IAAA,GAAA,KAAA,QAAA;AACA,WAAA,cAAA,CAAA,SAAA,GAAA,SAAA;AACA,WAAA,cAAA,CAAA,OAAA,GAAA,OAAA;AACA,WAAA,MAAA,CAAA,IAAA,CAAA,eAAA,EAAA,KAAA,cAAA,EAAA,IAAA,CAAA,GAAA,IAAA;AACA,cAAA;AAAA,UAAA;AAAA,YAAA,GAAA,CADA,CACA;;AACA,YAAA,IAAA,CAAA,IAAA,KAAA,GAAA,EAAA;AACA,eAAA,SAAA,GAAA,IAAA,CAAA,IAAA;AACA,eAAA,UAAA,GAAA,IAAA,CAAA,KAAA;AACA;AACA,OANA,EAMA,KANA,CAMA,KAAA,IAAA;AACA,aAAA,OAAA,CAAA,KAAA,CAAA;AACA,UAAA,KAAA,EAAA,MADA;AAEA,UAAA,OAAA,EAAA;AAFA,SAAA;AAIA,OAXA;AAYA,KAtFA;;AAuFA,IAAA,GAAA,GAAA;AACA,WAAA,qBAAA,GAAA,IAAA;AACA,KAzFA;;AA0FA,IAAA,YAAA,GAAA;AACA,WAAA,WAAA,GAAA,CAAA;AACA,WAAA,cAAA;AACA,KA7FA;;AA8FA,IAAA,iBAAA,GAAA;AACA,WAAA,YAAA;AACA,KAhGA;;AAiGA,IAAA,gBAAA,CAAA,GAAA,EAAA;AACA,WAAA,QAAA,GAAA,GAAA;AACA,WAAA,WAAA,GAAA,CAAA;AACA,WAAA,cAAA;AACA,KArGA;;AAsGA,IAAA,mBAAA,CAAA,GAAA,EAAA;AACA,WAAA,WAAA,GAAA,GAAA;AACA,WAAA,cAAA;AACA,KAzGA;;AA0GA,IAAA,cAAA,CAAA,SAAA,EAAA;AACA,WAAA,SAAA,GAAA,SAAA,CAAA,KAAA,CAAA,GAAA,CAAA;AACA,KA5GA;;AA6GA,IAAA,UAAA,CAAA,GAAA,EAAA;AACA,WAAA,IAAA,GAAA,GAAA;AACA,WAAA,cAAA,CAAA,GAAA,CAAA,YAAA;AACA,WAAA,qBAAA,GAAA,IAAA;AACA,KAjHA;;AAkHA,IAAA,YAAA,CAAA,GAAA,EAAA;AACA,WAAA,YAAA,CAAA,IAAA,CAAA,GAAA;AACA,WAAA,WAAA;AACA;;AArHA;AA7BA,CAAA","sourcesContent":["<template>\r\n    <el-row style=\"background-color: #FFFFFF;padding: 5px 0;border-radius: 5px;\">\r\n        <el-row style=\"padding: 10px;margin-left: 5px;\">\r\n            <el-row>\r\n                <span class=\"bargain\">\r\n                    <span\r\n                        :style=\"{ backgroundColor: tradeSelectedItem.name === bargain.name ? 'rgb(255,255,255)' : '' }\"\r\n                        @click=\"tradeSelected(bargain)\" v-for=\"(bargain, index) in tradeStatus\" :key=\"index\">{{\r\n                            bargain.name }}</span>\r\n                </span>\r\n                <span class=\"bargain\">\r\n                    <span\r\n                        :style=\"{ backgroundColor: refundSelectedItem.name === bargain.name ? 'rgb(255,255,255)' : '' }\"\r\n                        @click=\"refundSelected(bargain)\" v-for=\"(bargain, index) in refundStatus\" :key=\"index\">{{\r\n                            bargain.name }}</span>\r\n                </span>\r\n                <el-date-picker style=\"width: 216px;margin-right: 5px;\" @change=\"fetchFreshData\" size=\"small\"\r\n                    v-model=\"searchTime\" type=\"daterange\" range-separator=\"至\" start-placeholder=\"下单开始\"\r\n                    end-placeholder=\"下单结束\">\r\n                </el-date-picker>\r\n                <el-input size=\"small\" style=\"width: 166px;\" v-model=\"ordersQueryDto.code\" placeholder=\"订单号\" clearable\r\n                    @clear=\"handleFilterClear\">\r\n                    <el-button slot=\"append\" @click=\"handleFilter\" icon=\"el-icon-search\"></el-button>\r\n                </el-input>\r\n            </el-row>\r\n        </el-row>\r\n        <el-row style=\"margin: 0 22px;border-top: 1px solid rgb(245,245,245);\">\r\n            <el-table :stripe=\"true\" :data=\"tableData\">\r\n                <el-table-column prop=\"code\" width=\"140\" label=\"订单号\"></el-table-column>\r\n                <el-table-column prop=\"userAvatar\" width=\"68\" label=\"头像\">\r\n                    <template slot-scope=\"scope\">\r\n                        <el-avatar :size=\"25\" :src=\"scope.row.userAvatar\" style=\"margin-top: 10px;\"></el-avatar>\r\n                    </template>\r\n                </el-table-column>\r\n                <el-table-column prop=\"userName\" width=\"130\" label=\"用户\"></el-table-column>\r\n                <el-table-column prop=\"productTitle\" width=\"168\" label=\"订单名\"></el-table-column>\r\n                <el-table-column prop=\"buyPrice\" width=\"110\" label=\"购入价\"></el-table-column>\r\n                <el-table-column prop=\"buyNumber\" width=\"110\" label=\"购入数\"></el-table-column>\r\n                <el-table-column prop=\"createTime\" width=\"168\" label=\"发布时间\"></el-table-column>\r\n                <el-table-column prop=\"detail\" label=\"订单备注\"></el-table-column>\r\n                <el-table-column label=\"操作\" width=\"160\">\r\n                    <template slot-scope=\"scope\">\r\n                        <span class=\"text-button\" @click=\"handleEdit(scope.row)\">订单详情</span>\r\n                        <span class=\"text-button\" @click=\"handleDelete(scope.row)\">删除</span>\r\n                    </template>\r\n                </el-table-column>\r\n            </el-table>\r\n            <el-pagination style=\"margin:10px 0;float: right;\" @size-change=\"handleSizeChange\"\r\n                @current-change=\"handleCurrentChange\" :current-page=\"currentPage\" :page-sizes=\"[10, 20]\"\r\n                :page-size=\"pageSize\" layout=\"total, sizes, prev, pager, next, jumper\"\r\n                :total=\"totalItems\"></el-pagination>\r\n        </el-row>\r\n        <el-drawer title=\"订单详情\" :visible.sync=\"drawerProductOperaion\" :direction=\"direction\">\r\n            <div style=\"padding: 0 15px;\">\r\n                <div>\r\n                    <span class=\"dialog-hover\">产品封面图</span>\r\n                    <div class=\"detail-cover\">\r\n                        <div @click=\"coverExpansion(cover)\" class=\"cover\" v-for=\"(cover, index) in coverList\"\r\n                            :key=\"index\">\r\n                            <img :src=\"cover\">\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n                <div>\r\n                    <div>\r\n                        <span class=\"dialog-hover\">支付状态</span>\r\n                        <i v-if=\"!data.tradeStatus\" style=\"margin-right: 5px;font-size: 10px;color: rgb(253, 199, 50);\"\r\n                            class=\"el-icon-warning\"></i>\r\n                        <i v-else style=\"margin-right: 5px;color: rgb(253, 199, 50);\" class=\"el-icon-success\"></i>\r\n                        <span class=\"dialog-hover\" v-if=\"!data.tradeStatus\">未支付</span>\r\n                        <span class=\"dialog-hover\" v-else>已支付</span>\r\n                        <span class=\"dialog-hover\" v-if=\"data.tradeStatus\">支付时间：{{ data.tradeTime }}</span>\r\n                    </div>\r\n                    <div>\r\n                        <span class=\"dialog-hover\">退款状态</span>\r\n                        <i v-if=\"!data.refundStatus\" style=\"margin-right: 5px;font-size: 10px;color: rgb(253, 199, 50);\"\r\n                            class=\"el-icon-warning\"></i>\r\n                        <i v-else style=\"margin-right: 5px;color: rgb(253, 199, 50);\" class=\"el-icon-success\"></i>\r\n                        <span class=\"dialog-hover\" v-if=\"!data.refundStatus\">未申请</span>\r\n                        <span class=\"dialog-hover\" v-else>已申请</span>\r\n                        <span class=\"dialog-hover\" v-if=\"data.refundStatus\">退款时间：{{ data.refundTime }}</span>\r\n                    </div>\r\n                    <div>\r\n                        <span class=\"dialog-hover\">退款是否已经审核</span>\r\n                        <i v-if=\"!data.isRefundConfirm\" style=\"margin-right: 5px;font-size: 10px;color: rgb(253, 199, 50);\"\r\n                            class=\"el-icon-warning\"></i>\r\n                        <i v-else style=\"margin-right: 5px;color: rgb(253, 199, 50);\" class=\"el-icon-success\"></i>\r\n                        <span class=\"dialog-hover\" v-if=\"!data.isRefundConfirm\">未审核</span>\r\n                        <span class=\"dialog-hover\" v-else>已审核</span>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </el-drawer>\r\n        <el-dialog :visible.sync=\"dialogCoverExpansion\" width=\"35%\">\r\n            <div style=\"padding: 10px;display: flex;justify-content: center;align-items: center;\">\r\n                <img style=\"width: 100%;height: 500px;\" :src=\"cover\" alt=\"\" srcset=\"\">\r\n            </div>\r\n        </el-dialog>\r\n    </el-row>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n    data() {\r\n        return {\r\n            data: {},\r\n            currentPage: 1,\r\n            coverList: [],\r\n            searchTime: [],\r\n            cover: null, // 放大查看的产品图略\r\n            pageSize: 10,\r\n            totalItems: 0,\r\n            drawerProductOperaion: false, // 开关\r\n            isOperation: false, // 开关-标识新增或修改\r\n            tableData: [],\r\n            delectedRows: [],\r\n            dialogCoverExpansion: false,\r\n            ordersQueryDto: {}, // 搜索条件\r\n            direction: 'rtl', // 从右往左 right to left\r\n            categoryList: [],\r\n            tradeSelectedItem: {},\r\n            refundSelectedItem: {},\r\n            refundStatus: [{ refundStatus: null, name: '全部' }, { refundStatus: true, name: '已退款' }, { refundStatus: false, name: '未退款' }],\r\n            tradeStatus: [{ tradeStatus: null, name: '全部' }, { tradeStatus: true, name: '已下单' }, { tradeStatus: false, name: '未下单' }]\r\n        };\r\n    },\r\n    created() {\r\n        this.fetchFreshData();\r\n        // 页面加载时，默认不启用砍价查询条件\r\n        this.tradeSelected(this.tradeStatus[0]);\r\n    },\r\n    methods: {\r\n        /**\r\n         * 支付状态选中事件\r\n         * @param {*} bargain 支付状态\r\n         */\r\n        tradeSelected(trade) {\r\n            this.tradeSelectedItem = trade;\r\n            this.ordersQueryDto.tradeStatus = trade.tradeStatus;\r\n            this.fetchFreshData();\r\n        },\r\n        refundSelected(refund){\r\n            this.refundSelectedItem = refund;\r\n            this.ordersQueryDto.refundStatus = refund.refundStatus;\r\n            this.fetchFreshData(); \r\n        },\r\n        /**\r\n         * 产品图放大查看\r\n         * @param {*} cover 图片链接\r\n         */\r\n        coverExpansion(cover) {\r\n            this.cover = cover;\r\n            this.dialogCoverExpansion = true;\r\n        },\r\n        cannel() {\r\n            this.data = {};\r\n            this.drawerProductOperaion = false;\r\n            this.isOperation = false;\r\n        },\r\n        // 批量删除数据\r\n        async batchDelete() {\r\n            if (!this.delectedRows.length) {\r\n                this.$message(`未选中任何数据`);\r\n                return;\r\n            }\r\n            const confirmed = await this.$swalConfirm({\r\n                title: '删除订单数据',\r\n                text: `删除后不可恢复，是否继续？`,\r\n                icon: 'warning',\r\n            });\r\n            if (confirmed) {\r\n                try {\r\n                    let ids = this.delectedRows.map(entity => entity.id);\r\n                    const response = await this.$axios.post(`/orders/batchDelete`, ids);\r\n                    if (response.data.code === 200) {\r\n                        this.$notify({\r\n                            duration: 1000,\r\n                            title: '信息删除',\r\n                            message: '删除成功',\r\n                            type: 'success'\r\n                        });\r\n                        this.fetchFreshData();\r\n                        return;\r\n                    }\r\n                } catch (error) {\r\n                    this.$message.error(\"订单信息删除异常：\", error);\r\n                    console.error(`订单信息删除异常：`, error);\r\n                }\r\n            }\r\n        },\r\n        /**\r\n         * 订单查询\r\n         */\r\n        async fetchFreshData() {\r\n            let startTime = null;\r\n            let endTime = null;\r\n            if (this.searchTime != null && this.searchTime.length === 2) {\r\n                const [startDate, endDate] = await Promise.all(this.searchTime.map(date => date.toISOString()));\r\n                startTime = `${startDate.split('T')[0]}T00:00:00`;\r\n                endTime = `${endDate.split('T')[0]}T23:59:59`;\r\n            }\r\n            this.ordersQueryDto.current = this.currentPage;\r\n            this.ordersQueryDto.size = this.pageSize;\r\n            this.ordersQueryDto.startTime = startTime;\r\n            this.ordersQueryDto.endTime = endTime;\r\n            this.$axios.post('/orders/query', this.ordersQueryDto).then(res => {\r\n                const { data } = res; // 解构\r\n                if (data.code === 200) {\r\n                    this.tableData = data.data;\r\n                    this.totalItems = data.total;\r\n                }\r\n            }).catch(error => {\r\n                this.$notify.error({\r\n                    title: '查询操作',\r\n                    message: error\r\n                });\r\n            })\r\n        },\r\n        add() {\r\n            this.drawerProductOperaion = true;\r\n        },\r\n        handleFilter() {\r\n            this.currentPage = 1;\r\n            this.fetchFreshData();\r\n        },\r\n        handleFilterClear() {\r\n            this.handleFilter();\r\n        },\r\n        handleSizeChange(val) {\r\n            this.pageSize = val;\r\n            this.currentPage = 1;\r\n            this.fetchFreshData();\r\n        },\r\n        handleCurrentChange(val) {\r\n            this.currentPage = val;\r\n            this.fetchFreshData();\r\n        },\r\n        parseCoverList(coverList) {\r\n            this.coverList = coverList.split(',');\r\n        },\r\n        handleEdit(row) {\r\n            this.data = row;\r\n            this.parseCoverList(row.productCover);\r\n            this.drawerProductOperaion = true;\r\n        },\r\n        handleDelete(row) {\r\n            this.delectedRows.push(row);\r\n            this.batchDelete();\r\n        }\r\n    },\r\n};\r\n</script>\r\n<style scoped lang=\"scss\">\r\n.bargain {\r\n    display: inline-block;\r\n    font-size: 12px;\r\n    background-color: rgb(246, 246, 246);\r\n    line-height: 24px;\r\n    padding-inline: 10px;\r\n    padding-block: 4px;\r\n    margin-right: 5px;\r\n    border-radius: 5px;\r\n    cursor: pointer;\r\n\r\n    span {\r\n        display: inline-block;\r\n        padding-inline: 10px;\r\n        border-radius: 5px;\r\n    }\r\n}\r\n\r\n.detail-cover {\r\n    display: flex;\r\n    justify-content: left;\r\n    gap: 10px;\r\n\r\n    .cover {\r\n        padding: 10px;\r\n        box-sizing: border-box;\r\n        border-radius: 5px;\r\n        cursor: pointer;\r\n\r\n        img {\r\n            width: 100px;\r\n            height: 100px;\r\n        }\r\n    }\r\n\r\n    .cover:hover {\r\n        background-color: rgb(246, 246, 246);\r\n    }\r\n\r\n}\r\n</style>"],"sourceRoot":"src/views/admin"}]}