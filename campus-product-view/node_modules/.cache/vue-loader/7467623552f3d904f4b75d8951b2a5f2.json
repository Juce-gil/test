CA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;;AAEA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;;AAGA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA","file":"Home.vue","sourceRoot":"src/views/user","sourcesContent":["<template>\n    <div>\n        <div class=\"container\">\n            <div class=\"top\">\n                <div class=\"top-inner\">\n                    <div class=\"nav\">\n                        <div class=\"logo\">\n                            <Logo name=\"校园交易\" />\n                        </div>\n                        <div class=\"route\">\n                            <span @click=\"handleRouteSelect('/product')\">商品</span>\n                            <span v-if=\"loginStatus\" @click=\"handleRouteSelect('/myProduct')\">我的商品</span>\n                            <span v-if=\"loginStatus\" @click=\"handleRouteSelect('/mySave')\">我的收藏</span>\n                            <span v-if=\"loginStatus\" @click=\"handleRouteSelect('/myView')\">足迹</span>\n                        </div>\n                    </div>\n\n                    <div class=\"top-actions\">\n                        <div class=\"word-search\">\n                            <div class=\"item\">\n                                <input type=\"text\" placeholder=\"搜索商品\" v-model=\"key\">\n                                <i class=\"el-icon-search\" @click=\"fetch\"></i>\n                            </div>\n                        </div>\n\n                        <div class=\"action-icon\" v-if=\"loginStatus\" @click=\"handleRouteSelect('/orders')\">\n                            <i class=\"el-icon-document\"></i>\n                            <span>订单</span>\n                        </div>\n                        <div class=\"action-icon\" v-if=\"loginStatus\" @click=\"handleRouteSelect('/message')\">\n                            <i class=\"el-icon-bell\"></i>\n                            <span>通知</span>\n                        </div>\n\n                        <div class=\"action-primary\" v-if=\"loginStatus\" @click=\"handleRouteSelect('/post-product')\">\n                            <i class=\"el-icon-plus\"></i>\n                            <span>发布商品</span>\n                        </div>\n\n                        <div class=\"login-link\" v-if=\"!loginStatus\" @click=\"loginOperation\">\n                            登录&nbsp;|&nbsp;注册\n                        </div>\n                        <div v-else class=\"user-avatar\">\n                            <el-dropdown trigger=\"click\">\n                                <span class=\"user-entry\">\n                                    <img class=\"avatar\" :src=\"userInfo.userAvatar\">\n                                    <span class=\"user-name\" v-if=\"userInfo && userInfo.userName\">\n                                        {{ userInfo.userName }}\n                                    </span>\n                                    <i class=\"el-icon-arrow-down el-icon--right\"></i>\n                                </span>\n                                <el-dropdown-menu slot=\"dropdown\">\n                                    <el-dropdown-item icon=\"el-icon-user-solid\" @click.native=\"goProfile\">\n                                        个人中心\n                                    </el-dropdown-item>\n                                    <el-dropdown-item icon=\"el-icon-edit\" @click.native=\"goEditProfile\">\n                                        修改资料\n                                    </el-dropdown-item>\n                                    <el-dropdown-item divided icon=\"el-icon-switch-button\" @click.native=\"logout\">\n                                        退出登录\n                                    </el-dropdown-item>\n                                </el-dropdown-menu>\n                            </el-dropdown>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"info\" v-if=\"loginStatus\">\n                <div>\n                    <img :src=\"userInfo.userAvatar\" class=\"info-avatar\">\n                </div>\n                <div class=\"info-main\">\n                    <div class=\"title1\">\n                        <span class=\"title\">{{ userInfo.userName }}</span>\n                        <span  class=\"poin\" v-for=\"(info,index) in productInfoList\" :key=\"index\">\n                            {{info.name}}·{{ info.count }}\n                        </span>\n                    </div>\n                    <div class=\"date meta\">\n                        上一次登录时间： {{ userInfo.lastLoginTime }}\n                    </div>\n                    <div class=\"date meta\">\n                        注册于： {{ userInfo.createTime }}\n                    </div>\n                </div>\n            </div>\n        </div>\n        <div style=\"padding: 10px 300px;\">\n            <router-view></router-view>\n        </div>\n    </div>\n</template>\n<script>\nimport Logo from \"@/components/Logo\";\nimport { getToken, setUserInfo, setSearchKey, clearToken } from \"@/utils/storage\";\nexport default {\n    name: \"Home\",\n    components: {\n        Logo,\n    },\n    data() {\n        return {\n            selfPath: { name: '个人中心', path: '/mySelf' },\n            userRoutes: [],\n            key: null,\n            dialogOperaion: false,\n            loginStatus: false, // 默认未登录\n            userInfo: {},\n            searchPath: '/search',\n            productInfoList: []\n        };\n    },\n    created() {\n        // 只加载登录状态和用户信息，不做任何路由强制跳转\n        this.loadLoginStatus();\n    },\n    methods: {\n        queryProductInfo() {\n            this.$axios.post(`/product/queryProductInfo`, {}).then(res => {\n                const { data } = res;\n                if (data.code === 200) {\n                    this.productInfoList = data.data;\n                }\n                this.loginStatus = data.code === 200;\n            }).catch(error => {\n                console.log(\"商品指标查询异常：\", error);\n            });\n        },\n        // 跳转登录页\n        loginOperation() {\n            this.$router.push('/login');\n        },\n        // 搜索\n        fetch() {\n            setSearchKey(this.key);\n            this.handleRouteSelect(this.searchPath);\n        },\n        // 路由切换\n        handleRouteSelect(path) {\n            if (this.$router.currentRoute.fullPath !== path) {\n                this.$router.push(path);\n            }\n        },\n        //判断用户是否已经登录\n        loadLoginStatus() {\n            const token = getToken();\n            // 没登录\n            if (token === null) {\n                this.loginStatus = false;\n                return;\n            }\n            this.auth();\n        },\n        // token检验\n        auth() {\n            this.$axios.get(`/user/auth`).then(res => {\n                const { data } = res;\n                if (data.code === 200) {\n                    // 存储用户信息\n                    setUserInfo(data.data);\n                    this.userInfo = data.data;\n                    this.queryProductInfo();\n                }\n                this.loginStatus = data.code === 200;\n            }).catch(error => {\n                console.log(\"token检验异常：\", error);\n            });\n        },\n        goProfile() {\n            // 进入个人中心-修改资料\n            this.handleRouteSelect('/myself?tab=info');\n        },\n        goEditProfile() {\n            // 显式进入修改资料页，便于后续扩展其他 Tab\n            this.handleRouteSelect('/myself?tab=edit');\n        },\n        logout() {\n            clearToken();\n            sessionStorage.setItem('userInfo', null);\n            this.loginStatus = false;\n            this.$router.push('/login');\n        },\n    }\n};\n</script>\n<style scoped lang=\"scss\">\n.top-inner{\n    width: 100%;\n    max-width: 1180px;\n    margin: 0 auto;\n    padding: 0 24px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 18px;\n}\n\n.avatar {\n    border: 2px solid rgba(255,255,255,0.18);\n    width: 32px;\n    height: 32px;\n    border-radius: 50%;\n    object-fit: cover;\n    box-sizing: border-box;\n}\n\n.avatar:hover {\n    border: 2px solid rgba(255, 209, 80, 0.9);\n}\n\n.top-actions{\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    color: rgb(143, 143, 143);\n    flex: 0 0 auto;\n}\n.action-icon{\n    cursor: pointer;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    width: 44px;\n    gap: 4px;\n    user-select: none;\n    color: rgb(143, 143, 143);\n\n    i{\n        font-size: 18px;\n        line-height: 18px;\n    }\n    span{\n        font-size: 12px;\n        line-height: 12px;\n    }\n}\n.action-icon:hover{\n    color: rgb(255, 255, 255);\n}\n.action-primary{\n    cursor: pointer;\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    padding: 8px 12px;\n    border-radius: 999px;\n    background: rgba(255, 209, 80, 0.92);\n    color: rgb(51, 51, 51);\n    font-size: 14px;\n    font-weight: 700;\n    user-select: none;\n    white-space: nowrap;\n\n    i{\n        font-size: 16px;\n    }\n}\n.action-primary:hover{\n    background: rgba(255, 209, 80, 1);\n}\n.login-link{\n    cursor: pointer;\n    user-select: none;\n}\n.login-link:hover{\n    color: rgb(255, 255, 255);\n}\n.user-avatar{\n    display: flex;\n    align-items: center;\n}\n.user-entry{\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    cursor: pointer;\n    color: rgb(245,245,245);\n}\n.user-name{\n    max-width: 120px;\n    font-size: 13px;\n    white-space: nowrap;\n    text-overflow: ellipsis;\n    overflow: hidden;\n}\n\n.word-search {\n    display: flex;\n    justify-content: center;\n\n    .item {\n        max-width: 210px;\n        background-color: rgb(244, 244, 244);\n        border-radius: 20px;\n        display: flex;\n        justify-content: space-between;\n        align-items: center;\n        box-sizing: border-box;\n        border: 1px solid rgb(245, 245, 245);\n\n        input:focus {\n            width: 110px;\n        }\n\n        input {\n            border: none;\n            transition: all 0.6s;\n            width: 140px;\n            margin: 0 10px;\n            background-color: rgb(244, 244, 244);\n            outline: none;\n            font-size: 14px;\n        }\n\n        i {\n            padding: 6px 12px;\n            border-radius: 5px;\n            cursor: pointer;\n            border-top-right-radius: 20px;\n            border-bottom-right-radius: 20px;\n            background-color: rgb(244, 244, 244);\n        }\n\n        i:hover {\n            background-color: rgb(241, 241, 241);\n        }\n    }\n\n}\n\n.container {\n    background-color: rgb(51, 51, 51);\n}\n\n.info {\n    width: 100%;\n    max-width: 1180px;\n    margin: 0 auto;\n    padding: 10px 24px 16px 24px;\n    display: flex;\n    align-items: center;\n    gap: 14px;\n\n    .info-avatar{\n        width: 56px;\n        height: 56px;\n        border-radius: 50%;\n        object-fit: cover;\n        padding: 3px;\n        box-sizing: border-box;\n        border: 2px solid rgba(255,255,255,0.85);\n        background: rgba(255,255,255,0.08);\n    }\n\n    .info-main{\n        padding: 0;\n        min-width: 0;\n    }\n\n    .title1 {\n        font-size: 20px;\n        color: rgb(255, 255, 255);\n        gap: 12px;\n\n        .poin {\n            display: inline-block;\n            padding: 2px 6px;\n            margin-inline: 4px;\n            box-sizing: border-box;\n            border-radius: 20px;\n            cursor: pointer;\n            font-size: 10px;\n            color: rgb(255, 255, 255);\n            background-color: rgb(197, 153, 57);\n        }\n    }\n\n    .save,\n    .date {\n        margin: 6px 0;\n        font-size: 12px;\n        color: rgb(153, 150, 141);\n    }\n    .meta{\n        opacity: 0.85;\n    }\n\n}\n\n.top {\n\n    height: 80px;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n\n    .nav {\n        display: flex;\n        justify-content: left;\n        align-items: center;\n        gap: 18px;\n\n        .route {\n            display: flex;\n            justify-content: left;\n            align-items: center;\n            gap: 18px;\n\n\n            span {\n                font-size: 14px;\n                color: rgb(143, 143, 143);\n                cursor: pointer;\n            }\n\n            span:hover {\n                color: rgb(255, 255, 255);\n            }\n        }\n\n    }\n}\n</style>"]}]}