CA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;;AAEA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;;AAGA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA","file":"Home.vue","sourceRoot":"src/views/user","sourcesContent":["<template>\r\n    <div>\r\n        <div class=\"container\">\r\n            <div class=\"top\">\r\n                <div class=\"top-inner\">\r\n                    <div class=\"nav\">\r\n                        <div class=\"logo\">\r\n                            <Logo name=\"校园交易\" />\r\n                        </div>\r\n                        <div class=\"route\">\r\n                            <span @click=\"handleRouteSelect('/product')\">商品</span>\r\n                            <span v-if=\"loginStatus\" @click=\"handleRouteSelect('/myProduct')\">我的商品</span>\r\n                            <span v-if=\"loginStatus\" @click=\"handleRouteSelect('/mySave')\">我的收藏</span>\r\n                            <span v-if=\"loginStatus\" @click=\"handleRouteSelect('/myView')\">足迹</span>\r\n                        </div>\r\n                    </div>\r\n\r\n                    <div class=\"top-actions\">\r\n                        <div class=\"word-search\">\r\n                            <div class=\"item\">\r\n                                <input type=\"text\" placeholder=\"搜索商品\" v-model=\"key\">\r\n                                <i class=\"el-icon-search\" @click=\"fetch\"></i>\r\n                            </div>\r\n                        </div>\r\n\r\n                        <div class=\"action-icon\" v-if=\"loginStatus\" @click=\"handleRouteSelect('/orders')\">\r\n                            <i class=\"el-icon-document\"></i>\r\n                            <span>订单</span>\r\n                        </div>\r\n                        <div class=\"action-icon\" v-if=\"loginStatus\" @click=\"handleRouteSelect('/message')\">\r\n                            <i class=\"el-icon-bell\"></i>\r\n                            <span>通知</span>\r\n                        </div>\r\n\r\n                        <div class=\"action-primary\" v-if=\"loginStatus\" @click=\"handleRouteSelect('/post-product')\">\r\n                            <i class=\"el-icon-plus\"></i>\r\n                            <span>发布商品</span>\r\n                        </div>\r\n\r\n                        <div class=\"login-link\" v-if=\"!loginStatus\" @click=\"loginOperation\">\r\n                            登录&nbsp;|&nbsp;注册\r\n                        </div>\r\n                        <div v-else class=\"user-avatar\">\r\n                            <el-dropdown trigger=\"click\">\r\n                                <span class=\"user-entry\">\r\n                                    <img class=\"avatar\" :src=\"userInfo.userAvatar\">\r\n                                    <span class=\"user-name\" v-if=\"userInfo && userInfo.userName\">\r\n                                        {{ userInfo.userName }}\r\n                                    </span>\r\n                                    <i class=\"el-icon-arrow-down el-icon--right\"></i>\r\n                                </span>\r\n                                <el-dropdown-menu slot=\"dropdown\">\r\n                                    <el-dropdown-item icon=\"el-icon-user-solid\" @click.native=\"goProfile\">\r\n                                        个人中心\r\n                                    </el-dropdown-item>\r\n                                    <el-dropdown-item icon=\"el-icon-edit\" @click.native=\"goEditProfile\">\r\n                                        修改资料\r\n                                    </el-dropdown-item>\r\n                                    <el-dropdown-item divided icon=\"el-icon-switch-button\" @click.native=\"logout\">\r\n                                        退出登录\r\n                                    </el-dropdown-item>\r\n                                </el-dropdown-menu>\r\n                            </el-dropdown>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n            <div class=\"info\" v-if=\"loginStatus\">\r\n                <div>\r\n                    <img :src=\"userInfo.userAvatar\" class=\"info-avatar\">\r\n                </div>\r\n                <div class=\"info-main\">\r\n                    <div class=\"title1\">\r\n                        <span class=\"title\">{{ userInfo.userName }}</span>\r\n                        <span  class=\"poin\" v-for=\"(info,index) in productInfoList\" :key=\"index\">\r\n                            {{info.name}}·{{ info.count }}\r\n                        </span>\r\n                    </div>\r\n                    <div class=\"date meta\">\r\n                        上一次登录时间： {{ userInfo.lastLoginTime }}\r\n                    </div>\r\n                    <div class=\"date meta\">\r\n                        注册于： {{ userInfo.createTime }}\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n        <div style=\"padding: 10px 300px;\">\r\n            <router-view></router-view>\r\n        </div>\r\n    </div>\r\n</template>\r\n<script>\r\nimport Logo from \"@/components/Logo\";\r\nimport { getToken, setUserInfo, setSearchKey, clearToken } from \"@/utils/storage\";\r\nexport default {\r\n    name: \"Home\",\r\n    components: {\r\n        Logo,\r\n    },\r\n    data() {\r\n        return {\r\n            selfPath: { name: '个人中心', path: '/mySelf' },\r\n            userRoutes: [],\r\n            key: null,\r\n            dialogOperaion: false,\r\n            loginStatus: false, // 默认未登录\r\n            userInfo: {},\r\n            searchPath: '/search',\r\n            productInfoList: []\r\n        };\r\n    },\r\n    created() {\r\n        // 只加载登录状态和用户信息，不做任何路由强制跳转\r\n        this.loadLoginStatus();\r\n    },\r\n    methods: {\r\n        queryProductInfo() {\r\n            this.$axios.post(`/product/queryProductInfo`, {}).then(res => {\r\n                const { data } = res;\r\n                if (data.code === 200) {\r\n                    this.productInfoList = data.data;\r\n                }\r\n                this.loginStatus = data.code === 200;\r\n            }).catch(error => {\r\n                console.log(\"商品指标查询异常：\", error);\r\n            });\r\n        },\r\n        // 跳转登录页\r\n        loginOperation() {\r\n            this.$router.push('/login');\r\n        },\r\n        // 搜索\r\n        fetch() {\r\n            setSearchKey(this.key);\r\n            this.handleRouteSelect(this.searchPath);\r\n        },\r\n        // 路由切换\r\n        handleRouteSelect(path) {\r\n            if (this.$router.currentRoute.fullPath !== path) {\r\n                this.$router.push(path);\r\n            }\r\n        },\r\n        //判断用户是否已经登录\r\n        loadLoginStatus() {\r\n            const token = getToken();\r\n            // 没登录\r\n            if (token === null) {\r\n                this.loginStatus = false;\r\n                return;\r\n            }\r\n            this.auth();\r\n        },\r\n        // token检验\r\n        auth() {\r\n            this.$axios.get(`/user/auth`).then(res => {\r\n                const { data } = res;\r\n                if (data.code === 200) {\r\n                    // 存储用户信息\r\n                    setUserInfo(data.data);\r\n                    this.userInfo = data.data;\r\n                    this.queryProductInfo();\r\n                }\r\n                this.loginStatus = data.code === 200;\r\n            }).catch(error => {\r\n                console.log(\"token检验异常：\", error);\r\n            });\r\n        },\r\n        goProfile() {\r\n            // 进入个人中心-修改资料\r\n            this.handleRouteSelect('/myself?tab=info');\r\n        },\r\n        goEditProfile() {\r\n            // 显式进入修改资料页，便于后续扩展其他 Tab\r\n            this.handleRouteSelect('/myself?tab=edit');\r\n        },\r\n        logout() {\r\n            clearToken();\r\n            sessionStorage.setItem('userInfo', null);\r\n            this.loginStatus = false;\r\n            this.$router.push('/login');\r\n        },\r\n    }\r\n};\r\n</script>\r\n<style scoped lang=\"scss\">\r\n.top-inner{\r\n    width: 100%;\r\n    max-width: 1180px;\r\n    margin: 0 auto;\r\n    padding: 0 24px;\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: space-between;\r\n    gap: 18px;\r\n}\r\n\r\n.avatar {\r\n    border: 2px solid rgba(255,255,255,0.18);\r\n    width: 32px;\r\n    height: 32px;\r\n    border-radius: 50%;\r\n    object-fit: cover;\r\n    box-sizing: border-box;\r\n}\r\n\r\n.avatar:hover {\r\n    border: 2px solid rgba(255, 209, 80, 0.9);\r\n}\r\n\r\n.top-actions{\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 14px;\r\n    color: rgb(143, 143, 143);\r\n    flex: 0 0 auto;\r\n}\r\n.action-icon{\r\n    cursor: pointer;\r\n    display: flex;\r\n    flex-direction: column;\r\n    align-items: center;\r\n    justify-content: center;\r\n    width: 44px;\r\n    gap: 4px;\r\n    user-select: none;\r\n    color: rgb(143, 143, 143);\r\n\r\n    i{\r\n        font-size: 18px;\r\n        line-height: 18px;\r\n    }\r\n    span{\r\n        font-size: 12px;\r\n        line-height: 12px;\r\n    }\r\n}\r\n.action-icon:hover{\r\n    color: rgb(255, 255, 255);\r\n}\r\n.action-primary{\r\n    cursor: pointer;\r\n    display: inline-flex;\r\n    align-items: center;\r\n    gap: 6px;\r\n    padding: 8px 12px;\r\n    border-radius: 999px;\r\n    background: rgba(255, 209, 80, 0.92);\r\n    color: rgb(51, 51, 51);\r\n    font-size: 14px;\r\n    font-weight: 700;\r\n    user-select: none;\r\n    white-space: nowrap;\r\n\r\n    i{\r\n        font-size: 16px;\r\n    }\r\n}\r\n.action-primary:hover{\r\n    background: rgba(255, 209, 80, 1);\r\n}\r\n.login-link{\r\n    cursor: pointer;\r\n    user-select: none;\r\n}\r\n.login-link:hover{\r\n    color: rgb(255, 255, 255);\r\n}\r\n.user-avatar{\r\n    display: flex;\r\n    align-items: center;\r\n}\r\n.user-entry{\r\n    display: inline-flex;\r\n    align-items: center;\r\n    gap: 6px;\r\n    cursor: pointer;\r\n    color: rgb(245,245,245);\r\n}\r\n.user-name{\r\n    max-width: 120px;\r\n    font-size: 13px;\r\n    white-space: nowrap;\r\n    text-overflow: ellipsis;\r\n    overflow: hidden;\r\n}\r\n\r\n.word-search {\r\n    display: flex;\r\n    justify-content: center;\r\n\r\n    .item {\r\n        max-width: 210px;\r\n        background-color: rgb(244, 244, 244);\r\n        border-radius: 20px;\r\n        display: flex;\r\n        justify-content: space-between;\r\n        align-items: center;\r\n        box-sizing: border-box;\r\n        border: 1px solid rgb(245, 245, 245);\r\n\r\n        input:focus {\r\n            width: 110px;\r\n        }\r\n\r\n        input {\r\n            border: none;\r\n            transition: all 0.6s;\r\n            width: 140px;\r\n            margin: 0 10px;\r\n            background-color: rgb(244, 244, 244);\r\n            outline: none;\r\n            font-size: 14px;\r\n        }\r\n\r\n        i {\r\n            padding: 6px 12px;\r\n            border-radius: 5px;\r\n            cursor: pointer;\r\n            border-top-right-radius: 20px;\r\n            border-bottom-right-radius: 20px;\r\n            background-color: rgb(244, 244, 244);\r\n        }\r\n\r\n        i:hover {\r\n            background-color: rgb(241, 241, 241);\r\n        }\r\n    }\r\n\r\n}\r\n\r\n.container {\r\n    background-color: rgb(51, 51, 51);\r\n}\r\n\r\n.info {\r\n    width: 100%;\r\n    max-width: 1180px;\r\n    margin: 0 auto;\r\n    padding: 10px 24px 16px 24px;\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 14px;\r\n\r\n    .info-avatar{\r\n        width: 56px;\r\n        height: 56px;\r\n        border-radius: 50%;\r\n        object-fit: cover;\r\n        padding: 3px;\r\n        box-sizing: border-box;\r\n        border: 2px solid rgba(255,255,255,0.85);\r\n        background: rgba(255,255,255,0.08);\r\n    }\r\n\r\n    .info-main{\r\n        padding: 0;\r\n        min-width: 0;\r\n    }\r\n\r\n    .title1 {\r\n        font-size: 20px;\r\n        color: rgb(255, 255, 255);\r\n        gap: 12px;\r\n\r\n        .poin {\r\n            display: inline-block;\r\n            padding: 2px 6px;\r\n            margin-inline: 4px;\r\n            box-sizing: border-box;\r\n            border-radius: 20px;\r\n            cursor: pointer;\r\n            font-size: 10px;\r\n            color: rgb(255, 255, 255);\r\n            background-color: rgb(197, 153, 57);\r\n        }\r\n    }\r\n\r\n    .save,\r\n    .date {\r\n        margin: 6px 0;\r\n        font-size: 12px;\r\n        color: rgb(153, 150, 141);\r\n    }\r\n    .meta{\r\n        opacity: 0.85;\r\n    }\r\n\r\n}\r\n\r\n.top {\r\n\r\n    height: 80px;\r\n    display: flex;\r\n    justify-content: center;\r\n    align-items: center;\r\n\r\n    .nav {\r\n        display: flex;\r\n        justify-content: left;\r\n        align-items: center;\r\n        gap: 18px;\r\n\r\n        .route {\r\n            display: flex;\r\n            justify-content: left;\r\n            align-items: center;\r\n            gap: 18px;\r\n\r\n\r\n            span {\r\n                font-size: 14px;\r\n                color: rgb(143, 143, 143);\r\n                cursor: pointer;\r\n            }\r\n\r\n            span:hover {\r\n                color: rgb(255, 255, 255);\r\n            }\r\n        }\r\n\r\n    }\r\n}\r\n</style>"]}]}