{"remainingRequest":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!F:\\campus-system\\campus-system\\source code\\campus-product-view\\src\\views\\user\\Myself.vue?vue&type=style&index=0&id=f75d609c&scoped=true&lang=scss&","dependencies":[{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\src\\views\\user\\Myself.vue","mtime":1773295550757},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\css-loader\\dist\\cjs.js","mtime":1770519914693},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1770519917543},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\postcss-loader\\src\\index.js","mtime":1770519915224},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\sass-loader\\dist\\cjs.js","mtime":1770519914968},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1770519914424},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\vue-loader\\lib\\index.js","mtime":1770519916415}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Myself.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA+EA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;;;AAGA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA","file":"Myself.vue","sourceRoot":"src/views/user","sourcesContent":["<template>\n    <div class=\"container-self\">\n        <div class=\"container-self-top\">\n            <div class=\"title\">个人中心</div>\n        </div>\n        <div class=\"item\">\n            <span :style=\"{\n                fontWeight: tagSelected === tagItem ? '800' : '',\n                color: tagSelected === tagItem ? 'rgb(51,51,51)' : '',\n                backgroundColor: tagSelected === tagItem ? 'rgb(247, 247, 247)' : ''\n            }\" @click=\"condition(tagItem)\" v-for=\"(tagItem, index) in tags\" :key=\"index\">\n                {{ tagItem }}\n            </span>\n        </div>\n        <div v-if=\"tagSelected === '修改资料'\">\n            <Self />\n        </div>\n        <div v-else-if=\"tagSelected === '修改密码'\">\n            <ResetPwd />\n        </div>\n        <div v-else-if=\"tagSelected === '退出登录'\">\n            <el-result icon=\"warning\" title=\"退出\" subTitle=\"退出后将重新登录\">\n                <template slot=\"extra\">\n                    <span class=\"loginout\" @click=\"loginout\">我确定</span>\n                </template>\n            </el-result>\n        </div>\n    </div>\n</template>\n\n<script>\nimport ResetPwd from '@/views/user/ResetPwd'\nimport Self from '@/views/user/Self'\nexport default {\n    components: { ResetPwd, Self },\n    data() {\n        return {\n            tags: ['修改资料', '修改密码', '退出登录'],\n            tagSelected: '',\n            defaultPath: '修改资料',\n        };\n    },\n    created() {\n        this.syncTabFromRoute();\n    },\n    watch: {\n        '$route.query.tab': {\n            immediate: false,\n            handler() {\n                this.syncTabFromRoute();\n            }\n        }\n    },\n    methods: {\n        loginout() {\n            sessionStorage.setItem('token', null);\n            sessionStorage.setItem('userInfo', null);\n            this.$router.push('/login');\n        },\n        // 根据路由参数同步当前选中的标签\n        syncTabFromRoute() {\n            const tab = this.$route.query.tab;\n            if (tab === 'pwd') {\n                this.tagSelected = '修改密码';\n            } else {\n                // 默认或其他值都回到“修改资料”\n                this.tagSelected = this.defaultPath;\n            }\n        },\n        condition(tag) {\n            this.tagSelected = tag;\n        },\n        returnPage() {\n            this.$router.go(-1);\n        },\n    },\n};\n</script>\n<style scoped lang=\"scss\">\n.loginout{\n    display: inline-block;\n    color: rgb(245,245,245);\n    background-color: rgb(51,51,51);\n    border-radius: 5px;\n    padding: 4px 30px;\n    cursor: pointer;\n}\n.loginout:hover{\n    background-color: rgb(34, 34, 34);\n}\n.item {\n    width: 800px;\n    padding-block: 10px;\n    margin-block: 20px;\n    display: flex;\n    justify-content: left;\n    gap: 4px;\n\n    span {\n        font-size: 16px;\n        cursor: pointer;\n        display: inline-block;\n        transition: all .2s;\n        padding: 10px 20px;\n        border-radius: 10px;\n    }\n\n    span:hover {\n        background-color: rgb(246, 246, 246);\n    }\n\n}\n\n\n.container-self {\n    width: 800px;\n    margin: 0 auto;\n    padding: 50px 30px;\n\n    .container-self-top {\n        display: flex;\n        justify-content: left;\n        align-items: center;\n        gap: 8px;\n        margin-top: 15px;\n\n        .return-page {\n            padding: 20px;\n            border-radius: 5px;\n            cursor: pointer;\n        }\n\n        .return-page:hover {\n            background-color: rgb(248, 248, 248);\n        }\n\n        .title {\n            font-size: 30px;\n            font-weight: 800;\n        }\n    }\n}\n</style>"]}]}