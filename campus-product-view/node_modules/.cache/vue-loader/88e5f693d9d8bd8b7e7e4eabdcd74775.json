{"remainingRequest":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!F:\\campus-system\\campus-system\\source code\\campus-product-view\\src\\views\\user\\Message.vue?vue&type=style&index=0&id=5d22e93d&scoped=true&lang=scss&","dependencies":[{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\src\\views\\user\\Message.vue","mtime":1770603975130},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\css-loader\\dist\\cjs.js","mtime":1770519914693},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1770519917543},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\postcss-loader\\src\\index.js","mtime":1770519915224},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\sass-loader\\dist\\cjs.js","mtime":1770519914968},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1770519914424},{"path":"F:\\campus-system\\campus-system\\source code\\campus-product-view\\node_modules\\vue-loader\\lib\\index.js","mtime":1770519916415}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["Message.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA4DA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"Message.vue","sourceRoot":"src/views/user","sourcesContent":["<template>\r\n    <div class=\"message-container\">\r\n        <div class=\"clear-message\">\r\n            <span @click=\"messageIsRead\">\r\n                <i class=\"el-icon-s-open\"></i>\r\n            </span>\r\n        </div>\r\n        <div class=\"item\" v-for=\"(message,index) in messageList\" :key=\"index\">\r\n            <div class=\"bell\" :style=\"{backgroundColor: message.isRead ? 'rgb(246,246,246)' : 'rgb(239, 193, 87)'}\">\r\n                <i :style=\"{color: message.isRead ? 'rgb(51,51,51)' : 'rgb(246,246,246)'}\" class=\"el-icon-message-solid\">{{ message.isRead ? '已读' : '未读' }}</i>\r\n            </div>\r\n            <div>\r\n                <div class=\"content\">{{ message.content }}</div>\r\n                <div class=\"time\">{{ message.createTime }}</div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</template>\r\n<script>\r\nexport default {\r\n    name: 'Message',\r\n    data() {\r\n        return {\r\n            messageList: []\r\n        }\r\n    },\r\n    created() {\r\n        this.fetchMessage();\r\n    },\r\n    methods: {\r\n        messageIsRead(){\r\n            this.$axios.post(`/message/setRead`).then(res => {\r\n                const { data } = res; // 解构\r\n                if (data.code === 200) {\r\n                    this.$notify({\r\n                        duration: 1000,\r\n                        title: '消息清理成功',\r\n                        message: data.msg,\r\n                        type: 'success'\r\n                    });\r\n                    this.fetchMessage();\r\n                }\r\n            }).catch(error => {\r\n                console.log(\"消息已读设置异常：\", error);\r\n            })\r\n        },\r\n        fetchMessage() {\r\n            this.$axios.post(`/message/queryUser`,{}).then(res => {\r\n                const { data } = res; // 解构\r\n                if (data.code === 200) {\r\n                    this.messageList = data.data;\r\n                }\r\n            }).catch(error => {\r\n                console.log(\"查询消息异常：\", error);\r\n            })\r\n        },\r\n    }\r\n};\r\n</script>\r\n<style scoped lang=\"scss\">\r\n.message-container{\r\n    .clear-message{\r\n        margin-block: 10px;\r\n        display: flex;\r\n        justify-content: right;\r\n        span:hover{\r\n            background-color: rgb(241,241,241); \r\n        }\r\n        span{\r\n            display: flex;\r\n            justify-content: center;\r\n            align-items: center;\r\n            cursor: pointer;\r\n            width: 30px;\r\n            height: 30px;\r\n            border-radius: 50%;\r\n            background-color: rgb(246,246,246);\r\n        }\r\n    }\r\n    .item{\r\n        padding: 20px 10px;\r\n        display: flex;\r\n        justify-content: left;\r\n        gap: 20px;\r\n        align-items: center;\r\n        .content{\r\n            margin-block: 10px;\r\n            font-size: 18px;\r\n        }\r\n        .time{\r\n            margin-block: 2px;\r\n            font-size: 12px;\r\n        }\r\n        .bell:hover{\r\n            border: 2px solid rgb(220, 118, 44);\r\n        }\r\n        .bell{\r\n            width: 50px;\r\n            height: 50px;\r\n            border-radius: 50%;\r\n            display: flex;\r\n            align-items: center;\r\n            justify-content: center;\r\n            border: 2px solid rgb(252, 232, 210);\r\n            cursor: pointer;\r\n            transition: all .5s;\r\n            i{\r\n                font-size: 12px;\r\n                color: rgb(246,246,246);\r\n            }\r\n        }\r\n    }\r\n}\r\n</style>"]}]}